{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start Smart backend (serves frontend)",
			"type": "shell",
			"command": "npm",
			"args": [
				"--prefix",
				"backend",
				"start"
			],
			"isBackground": true,
			"problemMatcher": [],
